        "format-wifi": "{essid} ({signalStrength}%) п‡« ",
        "format-ethernet": "{ipaddr}/{cidr} (eth)",
        "format-linked": "{ifname} (No IP)",
        "format-disconnected": "Disconnected вљ ",
        "format-alt": "{ifname}: {ipaddr}/{cidr}",
        "on-click-right" : "foot -e nmtui"
    },
    "pulseaudio": {
        "scroll-step": 1, // %, can be a float
        "format": "{volume}% {icon}",
        "format-bluetooth": "{volume}% {icon} пЉ”",
        "format-bluetooth-muted": "{volume}% п‘¦ {icon} пЉ”",
        "format-muted": "{volume}% п‘¦",
        "format-source": "{volume}% п„°",
        "format-source-muted": "п„±",
        "format-icons": {
            "headphone": "пЂҐ",
            "headset": "пЂҐ",
            "phone": "п‚•",
            "portable": "п‚•",
            "car": "п†№",
            "default": ["пЂ¦", "пЂ§", "пЂЁ"]
        },
        "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
        "on-click-right": "foot -e pulsemixer",
    },
    "custom/archicon": {
        "format": "пЊѓ",
        "format-pending": "{} п‚ў",
        "return-type": "json",
        "exec": "swaync-client -swb",
        "on-click": "swaync-client -t -sw",
        "on-click-right": "swaync-client -d -sw",
        "escape": true
    },
    "custom/power": {
        "format" : "вЏ»",
		"on-click": "~/.config/hypr/scripts/power-menu.sh"
    }
}
