{
    "layer": "top",
    "position": "top",
    "margin-top": 5,
    "margin-right": 5,
    "margin-left": 5,
    "margin-up" : 5,
    "spacing": 10,
    "modules-left": [
        "custom/rofi-main-menu",
        "power-profiles-daemon",
        "idle_inhibitor",
        "backlight",
        "pulseaudio",
        "tray",
        "hyprland/workspaces"
//        "sway/workspaces"
    ],
    "modules-center": [
        //"hyprland/window"
        "clock"
    ],
    "modules-right": [
        "hyprland/language",
//        "sway/language",
//        "network", // use either nm-applet or this module 
        "cpu",
        "memory",
        "temperature",
        "custom/nvidia_temp",
        "battery",
	    "custom/archicon"
    ],
    "hyprland/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "warp-on-scroll": false,
        "format": "{name}",
    },

    "idle_inhibitor": {
        "format": "{icon} ",
        "format-icons": {
            "activated": "ÔĀģ",
            "deactivated": "ÔĀį"
        }
    },
    "hyprland/language": {
        "format": "{short}"
    },
    "tray": {
         "icon-size": 21,
        "spacing": 10,
         "icons": {
           "TelegramDesktop": "$HOME/.local/share/icons/hicolor/16x16/apps/telegram.png",
           "AyugramDesktop": "$HOME/.local/share/icons/hicolor/16x16/apps/telegram.png"
         }
    },
    "clock": {
        // "timezone": "America/New_York",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "format-alt": "{:%Y-%m-%d}"
    },
    "cpu": {
        "format": "{usage}% Ôčõ",
        "tooltip": false,
        "on-click": "foot -e btop"
    },
    "memory": {
        "format": "{}% ÔÉČ",
        "on-click": "foot -e htop"
    },
    "temperature": { // CPU
        // "thermal-zone": 2,
        // "hwmon-path": "/sys/class/hwmon/hwmon2/temp1_input",
        "critical-threshold": 60,
        "format-critical": "ÔčČ!{temperatureC}¬įC Ôčõ",
        "format": "ÔčČ {temperatureC}¬įC Ôčõ",
        "tooltip": true,
        "tooltip-format": "CPU"
    },
    "custom/nvidia_temp": {
        "format": "ÔčČ {}¬įC",
        "interval": 5,
        "exec": "nvidia-smi --query-gpu=temperature.gpu --format=csv,noheader,nounits",
        "tooltip": true,
        "tooltip-format": "GPU"
    },
    "backlight": {
        // "device": "acpi_video1",
        "format": "{percent}% {icon}",
        "format-icons": ["Óéć", "ÓŹď", "ÓŹĎ", "ÓŹŹ", "ÓŹé", "ÓŹć", "ÓŹä", "ÓŹą", "Óéõ"],
        "on-click":       "~/.config/hypr/scripts/blue-light-filter.sh up",
        "on-click-right": "~/.config/hypr/scripts/blue-light-filter.sh down"
    },
    "battery": {
        "bat": "BAT1",        // check /sys/class/power_supply/
        "adapter": "ADP1",    // check /sys/class/power_supply/
        "interval": 10,
        "full-at": 95,
        "design-capacity": false,
        "states": {
            "good": 95,
            "warning": 45,
            "critical": 25
        },
        "format": "{icon} {capacity}%",
        "format-charging": "ůįāĄ {capacity}%",
        "format-plugged": "ůįö• {capacity}%",
        "format-discharging": "{icon} {capacity}%",
        "format-icons": ["ůįāé", "ůįĀļ", "ůįĀĽ", "ůįĀľ", "ůįĀĹ", "ůįĀĺ", "ůįĀŅ", "ůįāÄ", "ůįāĀ", "ůįāā", "ůįĀĻ"],
        "tooltip": true,
        "tooltip-format": "{timeTo}\nConsumption: {power}W"
    },
    "power-profiles-daemon": {
      "format": "{icon}",
      "tooltip-format": "Power profile:{profile}\nDriver:{driver}",
      "tooltip": true,
      "format-icons": {
        "default": "ÔÉß",
        "performance": "ÔÉß",
        "balanced": "ÔČé",
        "power-saver": "ÔĀ¨"
      }
    },
    "network": {
        // "interface": "wlp2*", // (Optional) To force the use of this interface
        "format-wifi": "{essid} ({signalStrength}%) Ôáę ",
        "format-ethernet": "{ipaddr}/{cidr} (eth)",
        "format-linked": "{ifname} (No IP)",
        "format-disconnected": "Disconnected ‚ö†",
        "format-alt": "{ifname}: {ipaddr}/{cidr}",
        "on-click-right" : "foot -e nmtui"
    },
    "pulseaudio": {
    	"interaval": 1,
        "scroll-step": 1, // %, can be a float
        "format": "{volume}% {icon}",
        "format-bluetooth": "{volume}% {icon} ÔäĒ",
        "format-bluetooth-muted": "{volume}% ÔĎ¶ {icon} ÔäĒ",
        "format-muted": "{volume}% ÔĎ¶",
        "format-source": "{volume}% ÔĄį",
        "format-source-muted": "ÔĄĪ",
        "format-icons": {
            "headphone": "ÔÄ•",
            "headset": "ÔÄ•",
            "phone": "Ôāē",
            "portable": "Ôāē",
            "car": "ÔÜĻ",
            "default": ["ÔÄ¶", "ÔÄß", "ÔÄ®"]
        },
        "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
        "on-click-right": "foot -e pulsemixer",
    },
    "custom/archicon": {
        "format": "ÔĆÉ",
        "format-pending": "{} ÔāĘ",
        "return-type": "json",
        "exec": "swaync-client -swb",
        "on-click": "swaync-client -t -sw",
        "on-click-right": "swaync-client -d -sw",
        "escape": true
    },
    "custom/rofi-main-menu": {
        "format" : "ÔĆÉ",
		"on-click": "~/.config/rofi/scripts/main.sh"
    }
}
