{
    "layer": "top",
    "position": "top",
    "spacing": 10,
    "modules-left": [
        "custom/power-menu",
        "idle_inhibitor",
        "backlight",
        "pulseaudio",
        "niri/workspaces"
    ],
    "modules-center": [
        "clock"
    ],
    "modules-right": [
    	"tray",
        "niri/language",
//        "network", // use either nm-applet or this module 
        "cpu",
        "memory",
        "temperature",
        "custom/nvidia_temp",
        "battery",
	    "custom/archicon"
    ],
    "niri/workspaces": {
        "all-outputs": true,
        "format": "{index}",
    },

    "idle_inhibitor": {
        "format": "{icon} ",
        "format-icons": {
            "activated": "",
            "deactivated": ""
        }
    },
    "niri/language": {
        "format": "{short}"
    },
    "tray": {
         "icon-size": 21,
        "spacing": 10,
         "icons": {
           "TelegramDesktop": "$HOME/.local/share/icons/hicolor/16x16/apps/telegram.png",
           "AyugramDesktop": "$HOME/.local/share/icons/hicolor/16x16/apps/telegram.png"
         }
    },
    "clock": {
        // "timezone": "America/New_York",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "format-alt": "{:%Y-%m-%d}"
    },
    "cpu": {
        "format": " {usage}%",
        "tooltip": false,
        "on-click": "alacritty -e btop"
    },
    "memory": {
        "format": " {}%",
        "on-click": "alacritty -e htop"
    },
    "temperature": { // CPU
        // "thermal-zone": 2,
        // "hwmon-path": "/sys/class/hwmon/hwmon2/temp1_input",
        "critical-threshold": 70,
        "format-critical": "⚠️{temperatureC}⚠️°C",
        "format": "{temperatureC}°C",
        "tooltip": true,
        "tooltip-format": "CPU"
    },
    "custom/nvidia_temp": {
        "format": "{}°C",
        "interval": 5,
        "exec": "nvidia-smi --query-gpu=temperature.gpu --format=csv,noheader,nounits",
        "tooltip": true,
        "tooltip-format": "GPU"
    },
    "backlight": {
        // "device": "acpi_video1",
        "format": "{percent}% ",
        "tooltip": false,
        "on-click":       "~/.config/hypr/scripts/blue-light-filter.sh up",
        "on-click-right": "~/.config/hypr/scripts/blue-light-filter.sh down"
    },
    "battery": {
        "bat": "BAT1",        // check /sys/class/power_supply/
        "adapter": "ADP1",    // check /sys/class/power_supply/
        "interval": 10,
        "format": "{capacity}%",
        "format-charging": "󰂄 {capacity}%",
        "format-plugged": "󰚥 {capacity}%",
        "format-full": "󰚥 {capacity}%",
        "format-discharging": "󰂎 {capacity}%",
        "tooltip": true,
        "tooltip-format": "{timeTo}\nConsumption: {power}W"
    },
    "network": {
        // "interface": "wlp2*", // (Optional) To force the use of this interface
        "format-wifi": "{essid} ({signalStrength}%)  ",
        "format-ethernet": "{ipaddr}/{cidr} (eth)",
        "format-linked": "{ifname} (No IP)",
        "format-disconnected": "Disconnected ⚠",
        "format-alt": "{ifname}: {ipaddr}/{cidr}",
        "on-click-right" : "alacritty -e nmtui"
    },
    "pulseaudio": {
    	"interaval": 1,
        "scroll-step": 1, // %, can be a float
        "format": "{volume}% {icon}",
        "format-bluetooth": "{volume}% {icon} ",
        "format-bluetooth-muted": "{volume}%  {icon} ",
        "format-muted": "{volume}% ",
        "format-source": "{volume}% ",
        "format-source-muted": "",
        "format-icons": {
            "headphone": "",
            "headset": "",
            "phone": "",
            "portable": "",
            "car": "",
            "default": ["", "", ""]
        },
        "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
        "on-click-right": "alacritty -e pulsemixer",
    },
    "custom/archicon": {
        "format": "",
        "format-pending": "{} ",
        "return-type": "json",
        "exec": "swaync-client -swb",
        "on-click": "swaync-client -t -sw",
        "on-click-right": "swaync-client -d -sw",
        "escape": true
    },
    "custom/power-menu": {
        "format": "",
        "tooltip": false,
		"on-click": "~/.config/fuzzel/scripts/power-menu.sh"
    }
}
