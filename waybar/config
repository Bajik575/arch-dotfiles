{
    "layer": "top",
    "position": "top",
    "margin-top": 5,
    "margin-right": 5,
    "margin-left": 5,
    "margin-up" : 5,
    "spacing": 15,
    "modules-left": [
        "custom/power",
        "power-profiles-daemon",
        "idle_inhibitor",
        "backlight",
        "pulseaudio",
        "tray",
        "hyprland/workspaces"
//        "sway/workspaces"
    ],
    "modules-center": [
        //"hyprland/window"
        "clock"
    ],
    "modules-right": [
        "hyprland/language",
//        "sway/language",
        "network",
        "cpu",
        "memory",
        "temperature",
        "custom/nvidia_temp",
        "battery",
	    "custom/archicon"
    ],
    "hyprland/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "warp-on-scroll": false,
        "format": "{name}",
    },
    "mpd": {
        "format": "{stateIcon} {consumeIcon}{randomIcon}{repeatIcon}{singleIcon}{artist} - {album} - {title} ({elapsedTime:%M:%S}/{totalTime:%M:%S}) вёЁ{songPosition}|{queueLength}вё© {volume}% пЂЃ",
        "format-disconnected": "Disconnected пЂЃ",
        "format-stopped": "{consumeIcon}{randomIcon}{repeatIcon}{singleIcon}Stopped пЂЃ",
        "unknown-tag": "N/A",
        "interval": 5,
        "consume-icons": {
            "on": "пѓ„ "
        },
        "random-icons": {
            "off": "<span color=\"#f53c3c\">пЃґ</span> ",
            "on": "пЃґ "
        },
        "repeat-icons": {
            "on": "пЂћ "
        },
        "single-icons": {
            "on": "пЂћ1 "
        },
        "state-icons": {
            "paused": "пЃЊ",
            "playing": "пЃ‹"
        },
        "tooltip-format": "MPD (connected)",
        "tooltip-format-disconnected": "MPD (disconnected)"
    },

    "idle_inhibitor": {
        "format": "{icon} ",
        "format-icons": {
            "activated": "пЃ®",
            "deactivated": "пЃ°"
        }
    },
    "hyprland/language": {
        "format": "{short}"
    },
    "tray": {
         "icon-size": 21,
        "spacing": 10,
         "icons": {
           "TelegramDesktop": "$HOME/.local/share/icons/hicolor/16x16/apps/telegram.png",
           "AyugramDesktop": "$HOME/.local/share/icons/hicolor/16x16/apps/telegram.png"
         }
    },
    "clock": {
        // "timezone": "America/New_York",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "format-alt": "{:%Y-%m-%d}"
    },
    "cpu": {
        "format": "{usage}% п‹›",
        "tooltip": false,
        "on-click": "foot -e btop"
    },
    "memory": {
        "format": "{}% пѓ‰",
        "on-click": "foot -e htop"
    },
    "temperature": { // CPU
        // "thermal-zone": 2,
        // "hwmon-path": "/sys/class/hwmon/hwmon2/temp1_input",
        "critical-threshold": 60,
        "format-critical": "п‹‰!{temperatureC}В°C п‹›",
        "format": "п‹‰ {temperatureC}В°C п‹›",
        "tooltip": true,
        "tooltip-format": "CPU"
    },
    "custom/nvidia_temp": {
        "format": "п‹‰ {}В°C",
        "interval": 5,
        "exec": "nvidia-smi --query-gpu=temperature.gpu --format=csv,noheader,nounits",
        "tooltip": true,
        "tooltip-format": "GPU"
    },
    "backlight": {
        // "device": "acpi_video1",
        "format": "{percent}% {icon}",
        "format-icons": ["оЋЌ", "оЏ“", "оЏ‘", "оЏЏ", "оЏЋ", "оЏЌ", "оЏЉ", "оЏ€", "оЋ›"]
    },
    "battery": {
        "bat": "BAT1",        // check /sys/class/power_supply/
        "adapter": "ADP1",    // check /sys/class/power_supply/
        "interval": 10,
        "full-at": 95,
        "design-capacity": false,
        "states": {
            "good": 95,
            "warning": 45,
            "critical": 25
        },
        "format": "{icon} {capacity}%",
        "format-charging": "у°‚„ {capacity}%",
        "format-plugged": "у°љҐ {capacity}%",
        "format-discharging": "{icon} {capacity}%",
        "format-icons": ["у°‚Ћ", "у°Ѓє", "у°Ѓ»", "у°Ѓј", "у°ЃЅ", "у°Ѓѕ", "у°Ѓї", "у°‚Ђ", "у°‚Ѓ", "у°‚‚", "у°Ѓ№"],
        "tooltip": true,
        "tooltip-format": "{timeTo}\nConsumption: {power}W"
    },
    "power-profiles-daemon": {
      "format": "{icon}",
      "tooltip-format": "Power profile:{profile}\nDriver:{driver}",
      "tooltip": true,
      "format-icons": {
        "default": "пѓ§",
        "performance": "пѓ§",
        "balanced": "п‰Ћ",
        "power-saver": "пЃ¬"
      }
    },
    "network": {
