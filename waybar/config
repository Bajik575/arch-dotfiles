{
    "layer": "top",
    "position": "top",
    "spacing": 10,
    "modules-left": [
        "custom/fuzzel-menu",
//        "idle_inhibitor",
        "backlight",
        "pulseaudio",
        "niri/workspaces"
    ],
    "modules-center": [
        "clock"
    ],
    "modules-right": [
        "niri/language",
//        "network", // use either nm-applet or this module 
        "cpu",
        "memory",
        "cpu-temperature",
        "custom/gpu-temperature",
        "battery",
	    "tray",
	    "custom/archicon"
    ],
    "niri/workspaces": {
        "all-outputs": true,
        "format": "{index}",
    },

    "idle_inhibitor": {
        "format": "{icon} ",
        "format-icons": {
            "activated": "ÔĀģ",
            "deactivated": "ÔĀį"
        }
    },
    "niri/language": {
    	"on-click": "niri msg action switch-layout next",
    	"on-right-click": "niri msg action switch-layout prev",
        "format": "{short}"
    },
    "tray": {
         "icon-size": 21,
        "spacing": 10,
         "icons": {
           "TelegramDesktop": "$HOME/.local/share/icons/hicolor/16x16/apps/telegram.png",
           "AyugramDesktop": "$HOME/.local/share/icons/hicolor/16x16/apps/telegram.png"
         }
    },
    "clock": {
        // "timezone": "America/New_York",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "format-alt": "{:%Y-%m-%d}"
    },
    "cpu": {
        "format": "Ôčõ {usage}%",
        "tooltip": false,
        "on-click": "alacritty -e btop"
    },
    "memory": {
        "format": "ÔÉČ {}%",
        "on-click": "alacritty -e htop"
    },
    "cpu-temperature": { // CPU
        // "thermal-zone": 2,
        // "hwmon-path": "/sys/class/hwmon/hwmon2/temp1_input",
        "critical-threshold": 70,
        "format-critical": "ÔčČ‚ö†ÔłŹ{temperatureC}‚ö†ÔłŹ¬įC",
        "format": "ÔčČ{temperatureC}¬įC",
        "tooltip": true,
        "tooltip-format": "CPU"
    },
    "custom/gpu-temperature": {
        "format": "ÔčČ{}¬įC",
        "interval": 5,
        "exec": "nvidia-smi --query-gpu=temperature.gpu --format=csv,noheader,nounits",
        "tooltip": true,
        "tooltip-format": "GPU"
    },
    "backlight": {
        // "device": "acpi_video1",
        "format": "{percent}% ÓŹé",
        "tooltip": false,
        "on-click":       "~/.config/waybar/scripts/blue-light-filter.sh up",
        "on-click-right": "~/.config/waybar/scripts/blue-light-filter.sh down"
    },
    "battery": {
        "bat": "BAT1",        // check /sys/class/power_supply/
        "adapter": "ADP1",    // check /sys/class/power_supply/
        "interval": 10,
        "format": "{capacity}%",
        "format-charging": "ůįāĄ {capacity}%",
        "format-plugged": "ůįö• {capacity}%",
        "format-full": "ůįö• {capacity}%",
        "format-discharging": "ůįāé {capacity}%",
        "tooltip": true,
        "tooltip-format": "{timeTo}\nConsumption: {power}W"
    },
    "network": {
        // "interface": "wlp2*", // (Optional) To force the use of this interface
        "format-wifi": "{essid} ({signalStrength}%) Ôáę ",
        "format-ethernet": "{ipaddr}/{cidr} (eth)",
        "format-linked": "{ifname} (No IP)",
        "format-disconnected": "Disconnected ‚ö†",
        "format-alt": "{ifname}: {ipaddr}/{cidr}",
        "on-click-right" : "alacritty -e nmtui"
    },
    "pulseaudio": {
    	"interaval": 1,
        "scroll-step": 1, // %, can be a float
        "format": "{volume}% {icon}",
        "format-bluetooth": "{volume}% {icon} ÔäĒ",
        "format-bluetooth-muted": "{volume}% ÔĎ¶ {icon} ÔäĒ",
        "format-muted": "{volume}% ÔĎ¶",
        "format-source": "{volume}% ÔĄį",
        "format-source-muted": "ÔĄĪ",
        "format-icons": {
            "headphone": "ÔÄ•",
            "headset": "ÔÄ•",
            "phone": "Ôāē",
            "portable": "Ôāē",
            "car": "ÔÜĻ",
            "default": ["ÔÄ¶", "ÔÄß", "ÔÄ®"]
        },
        "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
        "on-click-right": "alacritty -e pulsemixer",
    },
    "custom/archicon": {
        "format": "ÔĆÉ",
        "format-pending": "{} ÔāĘ",
        "return-type": "json",
        "exec": "swaync-client -swb",
        "on-click": "swaync-client -t -sw",
        "on-click-right": "swaync-client -d -sw",
        "escape": true
    },
    "custom/fuzzel-menu": {
        "format": "ÔĆÉ",
        "tooltip": false,
		"on-click": "~/.config/fuzzel/scripts/menu.sh",
		"on-click-right": "~/.config/fuzzel/scripts/power-menu.sh"
    }
}
