[main]
font=JetBrains Mono Nerd Font:size=15:style=Bold

[cursor]
style=beam
blink=yes

[mouse]
hide-when-typing=yes

[scrollback]
lines=10000
multiplier=3.0

# Catppuccin Mocha Colors
# ~/.config/foot/foot.ini

[colors]
alpha=1
foreground=f5e0dc  # Розовато-белый (ярче)
background=11111b  # Более тёмный фон для контраста

# ЯРКИЕ основные цвета
regular0=313244   # Тёмно-синий
regular1=ff7b93   # Ярко-розовый
regular2=7ce38b   # Ярко-зелёный (лаймовый)
regular3=ffd76e   # Ярко-жёлтый (солнечный)
regular4=7aa2f7   # Ярко-голубой
regular5=bb9af7   # Ярко-фиолетовый
regular6=73daca   # Ярко-бирюзовый
regular7=c0caf5   # Светло-голубой

# ОЧЕНЬ ЯРКИЕ версии
bright0=3b4261    # Яркий тёмно-синий
bright1=ff7b93    # Очень яркий розовый
bright2=7ce38b    # Неоново-зелёный
bright3=ffd76e    # Золотисто-жёлтый
bright4=7aa2f7    # Электрический синий
bright5=bb9af7    # Сиреневый
bright6=73daca    # Аквамарин
bright7=a9b1d6    # Светло-серо-голубой
